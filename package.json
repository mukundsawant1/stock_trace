{
  "name": "tradesage",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.tradesage.app",
    "productName": "TradeSage",
    "files": ["dist/**/*", "electron/**/*"],
    "win": {
      "target": "portable"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "dist": "npm run build && electron-builder",
    "electron:dev": "concurrently \"vite --port 5173\" \"wait-on http://localhost:5173 && electron .\""
  },
  "dependencies": {
    "electron": "^26.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^2.9.0",
    "uuid": "^9.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.18",
    "electron-builder": "^24.0.0",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.4.4",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^7.0.1"
  }
}
